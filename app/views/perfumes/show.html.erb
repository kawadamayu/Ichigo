<div class="intoro">
 <h2>診断結果</h2>
 <p>あなたにおすすめのいちごタイプは…</p>
</div>

<%
# スコア
a1 = 0
a2 = 0
a3 = 0
a4 = 0
a5 = 0

# A1 甘さ重視
a1 += 1 if @perfume.question1 == "A"
a1 += 1 if @perfume.question6 == "A"
a1 += 1 if @perfume.question7 == "A"
a1 += 1 if @perfume.question10 == "A"

# A2 バランス
a2 += 1 if @perfume.question1 == "B"
a2 += 1 if @perfume.question7 == "B"
a2 += 1 if @perfume.question10 == "B"

# A3 さっぱり
a3 += 1 if @perfume.question1 == "C"
a3 += 1 if @perfume.question6 == "C"
a3 += 1 if @perfume.question7 == "C"

# A4 香り重視
a4 += 1 if @perfume.question3 == "A"
a4 += 1 if @perfume.question6 == "B"
a4 += 1 if @perfume.question10 == "C"

# A5 スイーツ
a5 += 1 if @perfume.question5 == "B"
a5 += 1 if @perfume.question9 == "A"

scores = {
  "A1" => a1,
  "A2" => a2,
  "A3" => a3,
  "A4" => a4,
  "A5" => a5
}

result = scores.max_by{|k,v| v}[0]
%>

<div class="result">

<% if result == "A1" %>

<h3>A1 甘さ重視タイプ</h3>
<p>甘くてジューシーないちごが好き</p>

<% elsif result == "A2" %>

<h3>A2 バランスタイプ</h3>
<p>甘さと酸味のバランスが好き</p>

<% elsif result == "A3" %>

<h3>A3 さっぱりタイプ</h3>
<p>爽やかな酸味が好き</p>

<% elsif result == "A4" %>

<h3>A4 香り重視タイプ</h3>
<p>香り豊かないちごが好き</p>

<% elsif result == "A5" %>

<h3>A5 スイーツタイプ</h3>
<p>デザート向きいちごが好き</p>

<% end %>

</div>

<%= link_to "一覧に戻る", perfumes_path %>