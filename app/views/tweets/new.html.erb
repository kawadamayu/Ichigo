<div class="form-page">
  <div class="form-card">
    <h1>🍓 新規投稿 🍓</h1>
    <p class="form-subtitle">お気に入りのいちごを投稿しよう</p>

    <% if @tweet.errors.any? %>
      <div class="error-box">
        <% @tweet.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_for @tweet, html: { multipart: true } do |f| %>
      <div class="form-group">
        <%= f.label :title, "いちごの名前" %>
        <%= f.text_field :title, class: "form-input", placeholder: "例：あまおう" %>
      </div>

      <div class="form-group">
        <%= f.label :sweet, "甘さ" %>
        <%= f.select :sweet, [["★", 1], ["★★", 2], ["★★★", 3]], { include_blank: "選択してください" }, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= f.label :place, "購入場所・産地" %>
        <%= f.text_field :place, class: "form-input", placeholder: "例：福岡県 / スーパー" %>
      </div>

      <div class="form-group">
        <%= f.label :price, "値段" %>
        <%= f.text_field :price, class: "form-input", placeholder: "例：598円" %>
      </div>

      <div class="form-group">
        <%= f.label :image, "画像" %>
        <%= f.file_field :image, class: "form-input" %>
      </div>

      <div class="form-actions">
        <%= f.submit "投稿する", class: "main-btn" %>
      </div>
    <% end %>

    <div class="detail-actions">
      <%= link_to "一覧に戻る", tweets_path, class: "sub-btn" %>
    </div>
  </div>
</div>